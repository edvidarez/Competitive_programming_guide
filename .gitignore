# IOI: solo se versionan los enunciados (statement.pdf).
# El material pesado y/o con soluciones se conserva localmente pero NO se sube.
IOI/*/_local/

# OMI: se versionan los enunciados (statement.md / statement.pdf), imágenes y meta.json.
# Casos de prueba, soluciones de referencia, códigos y HTML crudo viven en
# <año>/<problema>/_local/ (dos niveles) y NO se suben.
OMI/**/_local/

*.part

# macOS
.DS_Store
